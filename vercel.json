{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "devCommand": "echo 'Static site'",
  "routes": [
    {
      "src": "/style.css",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/script.js",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
